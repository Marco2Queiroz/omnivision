# Appwrite (projeto omnivision — Cloud)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://sfo.cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=69c9ddd90025ff57dc52

# Servidor: API key com permissão a Databases (nunca no cliente)
APPWRITE_API_KEY=

# Banco Appwrite — coleção de planos Geo (atributos: titulo, descricao, status, owner_name)
APPWRITE_DATABASE_ID=
APPWRITE_GEO_COLLECTION_ID=

# Jira Cloud — só servidor
JIRA_HOST=https://your-domain.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=

# Opcional: dev sem cookie de sessão
# OMNI_DEV_SKIP_AUTH=true

# WhatsApp: DDI+número só dígitos
# NEXT_PUBLIC_WHATSAPP_FALLBACK=5511999990000

# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Jira Cloud — nunca expor no cliente; só servidor/API routes
JIRA_HOST=https://your-domain.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=

# Opcional: desativar proteção de rotas em dev quando Supabase não está configurado
# OMNI_DEV_SKIP_AUTH=true

# WhatsApp: DDI+número só dígitos, para botões de contato quando não há telefone no Jira
# NEXT_PUBLIC_WHATSAPP_FALLBACK=5511999990000

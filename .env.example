# Appwrite (projeto omnivision — Cloud)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://sfo.cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=69c9ddd90025ff57dc52

# Servidor: API key com permissão a Databases (nunca no cliente)
APPWRITE_API_KEY=

# Banco Appwrite — usado por gestão de acesso e futuras coleções (ex.: importação Excel)
APPWRITE_DATABASE_ID=

# Portfólio de projetos (tabela do dashboard). Crie a coleção no Console com os atributos usados em `mapAppwriteProjectDocument`.
# Padrão do ID se vazio: projects
APPWRITE_PROJECTS_COLLECTION_ID=

# Gestão de acesso — perfis (user_id, email, name, role, active). Coleção criada pela UI ou initAccessCollection.
# Padrão do ID da coleção se vazio: access_profiles
APPWRITE_ACCESS_COLLECTION_ID=

# Admin Console — documento singleton de parametrização (hour_value, capex_formula, ui_preferences JSON)
# Coleção padrão: app_settings | documento padrão: default
APPWRITE_APP_SETTINGS_COLLECTION_ID=
# APPWRITE_APP_SETTINGS_DOC_ID=default

# Status exibidos no dashboard (CRUD em /settings)
APPWRITE_STATUS_CONFIG_COLLECTION_ID=

# Histórico de importações Excel
APPWRITE_IMPORT_LOGS_COLLECTION_ID=

# Import Excel: nome exato da aba (opcional). Se vazio, usa a primeira aba do .xlsx
# NEXT_PUBLIC_EXCEL_IMPORT_SHEET=LISTA DE PROJETOS TI

# Valor hora padrão quando não há documento em app_settings
# NEXT_PUBLIC_DEFAULT_HOUR_VALUE=150

# Seed do usuário local de teste (só com NODE_ENV=development ou SEED_TEST_USER=true)
# SEED_TEST_USER=true
# SEED_TEST_USER_EMAIL=teste.local@omnivision.local
# SEED_TEST_USER_PASSWORD=Omnivision2026!
# SEED_TEST_USER_NAME=Usuário teste local

# PWA: o plugin `next-pwa` foi removido (conflitava com PostCSS/Tailwind). O `public/manifest.json`
# continua a permitir "Adicionar ao ecrã". Service worker em `public/sw.js` pode ser atualizado manualmente.

# Desenvolvimento: não defina NODE_ENV=production no .env — `npm install` omitiria devDependencies (TypeScript, Tailwind, etc.).
# No PowerShell, se o utilizador tiver NODE_ENV=production, corra `Remove-Item Env:NODE_ENV` antes de `npm install`.
# Não use NODE_OPTIONS com --disallow-code-generation-from-strings (o middleware do Next.js falha com EvalError).
# Os scripts `npm run dev|build|start` ignoram NODE_OPTIONS ao lançar o Next.

# Auth no middleware: em localhost ou `npm run dev` o login é ignorado (vai direto ao /dashboard).
# Em produção (NODE_ENV=production) o login nunca é contornado, exceto o par abaixo (não recomendado).
# Forçar tela de login no mesmo ambiente:
# FORCE_LOGIN=true
# ou: REQUIRE_AUTH_IN_DEV=true
# Forçar skip em host não-local (evitar): OMNI_SKIP_LOGIN=true
# Não usar: OMNI_ALLOW_BYPASS_IN_PROD=true (só com OMNI_SKIP_LOGIN; bypass em produção)

# Health: em produção a resposta é mínima; para detalhes: OMNI_VERBOSE_HEALTH=true
# Rate limit das API (por instância): OMNI_API_RATE_MAX=60  OMNI_API_RATE_WINDOW_MS=60000

# WhatsApp: DDI+número só dígitos
# NEXT_PUBLIC_WHATSAPP_FALLBACK=5511999990000
